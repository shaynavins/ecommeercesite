# PostgreSQL connection string from the Lynq deployment output.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lynq_database_name
PORT=3001

# Optional API auth. Set this in production and send Authorization: Bearer <token>.
API_BEARER_TOKEN=

# Comma-separated frontend origins allowed to call this backend.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Basic per-IP request limit.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
